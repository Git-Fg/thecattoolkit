{
  "description": "thecattoolkit hooks: file protection, security checks, and type-checking",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'command -v uv >/dev/null 2>&1 && uv run ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/protect-files.py || python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/protect-files.py'"
          },
          {
            "type": "command",
            "command": "sh -c 'command -v uv >/dev/null 2>&1 && uv run ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/security-check.py || python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/security-check.py'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'command -v uv >/dev/null 2>&1 && uv run ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/type-check-on-edit.py || python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/type-check-on-edit.py'",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}